# Copy to .dev.vars (gitignored) for `pnpm dev:db` local development.
# Production secrets are set via:
#   pnpm exec wrangler secret put JWT_SECRET           --config workers/db-worker/wrangler.jsonc
#   pnpm exec wrangler secret put ADMIN_KEY            --config workers/db-worker/wrangler.jsonc
#   pnpm exec wrangler secret put GOOGLE_CLIENT_SECRET --config workers/db-worker/wrangler.jsonc
# (repeat with `--env dev` for the dev worker)
# GOOGLE_CLIENT_ID is public and lives in wrangler.jsonc "vars".

JWT_SECRET=dev-only-secret-change-me
ADMIN_KEY=dev-admin-key

# OAuth 2.0 Client ID (Web application) from Google Cloud Console.
GOOGLE_CLIENT_ID=144271507987-du7ue2880rjbn83felsak0j3fefukkuq.apps.googleusercontent.com

# OAuth client secret (same Google Cloud OAuth client) — needed for the
# Google sign-in redirect flow (/api/auth/google/start|callback). The
# worker's /api/auth/google/callback URL must be registered as an
# Authorized redirect URI on that client (incl. http://localhost:8787
# for local dev).
GOOGLE_CLIENT_SECRET=

# Optional: extra app origins allowed as returnTo targets (comma-separated).
# Defaults already cover mercurypitch.com, dev.mercurypitch.com and localhost:3000.
#APP_ORIGINS=
