# ============================================================
# MercuryPitch Environment Configuration
# ============================================================
# Copy this to .env.local for local overrides (gitignored).
# .env is committed — safe defaults only, no secrets.

# ── Domains ──────────────────────────────────────────────────
VITE_PROD_DOMAIN=mercurypitch.com
VITE_DEV_DOMAIN=dev.mercurypitch.com

# ── Ports ────────────────────────────────────────────────────
VITE_DEV_PORT=3000
VITE_UVR_PROXY_PORT=8000
VITE_E2E_PORT=3001

# ── UVR API (server-side, not VITE_ prefixed) ────────────────
UVR_API_PORT=8080
UVR_API_HOST=0.0.0.0

# ── CORS Origins (comma-separated, used by uvr-api) ──────────
CORS_ORIGINS=https://mercurypitch.com,https://dev.mercurypitch.com

# ── ONNX WASM Base URL ───────────────────────────────────────
VITE_ONNX_WASM_BASE_URL=https://pub-2aafe9bb91454abb998beb378a16d44a.r2.dev/

# ── RunPod serverless GPU separation (worker secrets, NOT VITE_) ──
# The Cloudflare worker dispatches /api/uvr/* to a RunPod serverless endpoint
# when these are set AND the request opts in (off by default — see
# docs/claude/RUNPOD.md). Set them as wrangler secrets, not here:
#   wrangler secret put RUNPOD_API_KEY     --env prod
#   wrangler secret put RUNPOD_ENDPOINT_ID --env prod
# For local `wrangler dev`, copy .dev.vars.example → .dev.vars (gitignored).
# RUNPOD_BASE_URL is optional (defaults to https://api.runpod.ai/v2).
#
# The RunPod worker image (runpod/) reads its own S3/R2 output-storage env
# (S3_BUCKET, S3_ENDPOINT_URL, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY,
# S3_PUBLIC_BASE_URL) — configured on the RunPod endpoint, not in this app.
