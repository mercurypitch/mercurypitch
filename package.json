{
  "name": "pitch-perfect-app",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "serve": "npx http-server dist -p 4173 -c-1",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier src --check",
    "fmt:write": "prettier src --write",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lines": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'",
    "check:syntax": "run-s typecheck lint fmt"
  },
  "dependencies": {
    "solid-js": "^1.9.12",
    "midi-writer-js": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/ui": "^4.1.5",
    "cloc": "^2.6.0-cloc",
    "eslint": "9.39.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "npm-run-all": "^4.1.5",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-one-line-imports": "^1.0.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "8.58.2",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^4.1.5"
  }
}