{
  "name": "mercury-pitch",
  "version": "0.7.19",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "cross-env VITE_OVERRIDE_ONNX_MODEL= vite",
    "dev:host": "cross-env VITE_OVERRIDE_ONNX_MODEL= vite --host",
    "dev:jam": "cd workers/jam-worker && npx wrangler dev --port 8787 --live-reload",
    "dev:db": "cd workers/db-worker && npx wrangler dev --port 8788 --live-reload",
    "build": "vite build",
    "build:tours": "cross-env VITE_API_BASE_URL= VITE_OVERRIDE_ONNX_MODEL= VITE_GOOGLE_ADS_TAG_ID= VITE_GA4_MEASUREMENT_ID= vite build",
    "build:e2e": "cross-env VITE_API_BASE_URL= VITE_GOOGLE_ADS_TAG_ID= VITE_GA4_MEASUREMENT_ID= vite build",
    "build:dev": "vite build --mode development",
    "preview": "cross-env VITE_OVERRIDE_ONNX_MODEL= vite preview",
    "prod": "cross-env VITE_OVERRIDE_ONNX_MODEL= vite build && vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:tours": "node scripts/walk-tours.mjs",
    "audit:mobile": "node scripts/audit-exercises-mobile.mjs",
    "serve": "pnpm dlx http-server dist -p 4173 -c-1",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier src --check",
    "fmt:write": "prettier src --write --log-level warn",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:audit": "eslint -c eslint.audit.config.js src workers",
    "lines": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'",
    "check:syntax": "run-s typecheck lint fmt",
    "check": "run-s typecheck lint:fix fmt:write",
    "deploy:dev": "pnpm exec wrangler deploy --env dev",
    "deploy:prod": "pnpm exec wrangler deploy --env prod",
    "deploy:jam:dev": "cd workers/jam-worker && pnpm exec wrangler deploy --env dev",
    "deploy:jam:prod": "cd workers/jam-worker && pnpm exec wrangler deploy --env prod",
    "deploy:all:dev": "run-s deploy:dev deploy:jam:dev",
    "deploy:all:prod": "run-s deploy:prod deploy:jam:prod",
    "db:init": "./scripts/init-cloudflare-db.sh all prod",
    "db:init:dev": "./scripts/init-cloudflare-db.sh all dev",
    "db:init:local": "./scripts/init-cloudflare-db.sh --local",
    "db:seed": "node scripts/seed-remote-db.mjs",
    "deploy:db:dev": "cd workers/db-worker && pnpm exec wrangler deploy --env dev",
    "deploy:db:prod": "cd workers/db-worker && pnpm exec wrangler deploy --env prod",
    "typecheck:db": "tsc -p workers/db-worker",
    "size": "vite build && du -sh dist/assets/*.js dist/assets/*.css dist/assets/*.wasm 2>/dev/null | sort -rh"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.3",
    "@coderline/alphatab": "^1.8.3",
    "@huggingface/transformers": "^4.2.0",
    "dexie": "^4.4.2",
    "fflate": "^0.8.3",
    "lightningcss": "^1.32.0",
    "onnxruntime-web": "^1.25.1",
    "solid-js": "^1.9.12",
    "typegpu": "^0.11.9",
    "wgpu-matrix": "^3.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@webgpu/types": "^0.1.71",
    "cloc": "^2.6.0-cloc",
    "cross-env": "^10.1.0",
    "eslint": "9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-sonarjs": "^4.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-one-line-imports": "^1.0.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "8.58.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "unplugin-typegpu": "^0.11.6",
    "vite": "^6.0.0",
    "vite-plugin-qrcode": "^0.4.1",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.105.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
