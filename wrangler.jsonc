{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pitch-perfect",
  "compatibility_date": "2026-04-30",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "main": "src/index.js",
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "mercurypitch.com", "custom_domain": true }
  ],
  "env": {
    "dev": {
      "name": "pitch-perfect-dev",
      "routes": [
        { "pattern": "dev.mercurypitch.com", "custom_domain": true }
      ]
    }
  }
}
